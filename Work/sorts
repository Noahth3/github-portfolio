void calcResults(Results& result)
{
    result.avgCompares = ((result.ordCompares + result.revOrdCompares + result.unOrdCompares) / 3);
    result.avgCopies = ((result.ordCopies + result.revOrdCopies + result.unOrdCopies) / 3);
}

